{
  "name": "@codexremote/server",
  "version": "0.1.4",
  "private": true,
  "description": "Fastify backend for CodexRemote",
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@codexremote/shared": "*",
    "@fastify/multipart": "^9.0.0",
    "@fastify/rate-limit": "^10.3.0",
    "better-sqlite3": "^12.8.0",
    "fastify": "^5.3.3"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.15.3",
    "tsx": "^4.19.4",
    "typescript": "^5.7.0",
    "vitest": "^4.1.2"
  }
}
